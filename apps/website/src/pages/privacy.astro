---
import Base from '../layouts/Base.astro';
---
<Base title="Privacy — Shnappy">
  <div class="layout__section layout__section--white">
    <div class="center center--960">
      <div class="typography">
        <h1>Privacy Policy</h1>
        <p>Shnappy ("we") respects your privacy. This page summarises what data we collect, how we use it, and your choices.</p>

        <h2>Data we collect</h2>
        <ul>
          <li>Account information you provide (name, email, password).</li>
          <li>Photos and content you upload, stored in your linked Dropbox or our managed storage.</li>
          <li>Usage analytics to help us improve the product.</li>
        </ul>

        <h2>How we use your data</h2>
        <p>We use your data to deliver the Shnappy service: hosting your galleries, notifying you of client activity, billing your subscription, and providing support.</p>

        <h2>Sharing</h2>
        <p>We do not sell your personal data. We share data only with the service providers needed to run Shnappy (payment processing, email delivery, hosting) under strict confidentiality.</p>

        <h2>Your choices</h2>
        <p>You can export or delete your account data at any time from your account settings, or by emailing <a href="mailto:contact@shnappy.com">contact@shnappy.com</a>.</p>
      </div>
    </div>
  </div>
</Base>
